{
  "chapter_id": "01-health-check",
  "version": "1.0.0",
  "setup": [],
  "tests": [
    {
      "id": "get-health-status-200",
      "name": "GET /health returns 200",
      "description": "Health check endpoint must respond with HTTP 200",
      "request": {
        "method": "GET",
        "path": "/health"
      },
      "assert": {
        "status": 200
      }
    },
    {
      "id": "get-health-body-status-ok",
      "name": "GET /health body has status: ok",
      "description": "Response body must be {\"status\": \"ok\"}",
      "request": {
        "method": "GET",
        "path": "/health"
      },
      "assert": {
        "status": 200,
        "body": {
          "status": { "$eq": "ok" }
        }
      }
    }
  ]
}
